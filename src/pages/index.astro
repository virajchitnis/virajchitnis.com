---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ContactForm from '../components/ContactForm.astro';
import { getEntry } from 'astro:content';

const profileEntry = await getEntry('profile', 'profile');
if (!profileEntry) throw new Error('Missing src/content/profile.md entry');
---

<BaseLayout title={profileEntry.data.name} description={profileEntry.data.tagline}>
  <div class="page">
    <Hero name={profileEntry.data.name} tagline={profileEntry.data.tagline} />
    <SocialLinks links={profileEntry.data.links} />
    <ContactForm />
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }
</style>
