---
interface Link {
  label: string;
  url: string;
}

interface Props {
  links: Link[];
}

const { links } = Astro.props;

const icons: Record<string, string> = {
  GitHub:
    'M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.5 0-.24-.01-1.05-.01-1.9-2.78.62-3.37-1.19-3.37-1.19-.46-1.2-1.11-1.52-1.11-1.52-.91-.64.07-.63.07-.63 1 .07 1.53 1.05 1.53 1.05.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.32.1-2.75 0 0 .84-.27 2.75 1.05a9.3 9.3 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.43.2 2.49.1 2.75.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.5A10.03 10.03 0 0 0 22 12.25C22 6.58 17.52 2 12 2z',
  LinkedIn:
    'M4.98 3.5C4.98 4.88 3.94 6 2.5 6S0 4.88 0 3.5 1.06 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8.5h4V23h-4V8.5zm7.5 0h3.84v1.98h.05c.54-1 1.85-2.06 3.8-2.06 4.06 0 4.81 2.67 4.81 6.14V23h-4v-6.6c0-1.57-.03-3.6-2.2-3.6-2.2 0-2.53 1.72-2.53 3.48V23h-4V8.5z',
};
---

<nav class="social-links" aria-label="Elsewhere">
  {
    links.map((link) => (
      <a class="external" href={link.url} rel="me noopener noreferrer" target="_blank">
        {icons[link.label] && (
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d={icons[link.label]} />
          </svg>
        )}
        {link.label}
      </a>
    ))
  }
  <a class="primary" href="#contact">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2.5" y="5" width="19" height="14" rx="2"></rect>
      <path d="m3.5 6.5 8.5 6 8.5-6"></path>
    </svg>
    Get in touch
  </a>
</nav>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-6);
    padding: var(--space-6) 0;
    border-top: 1px solid var(--border);
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .social-links a:hover {
    text-decoration: underline;
  }

  .social-links .external svg {
    color: var(--accent-secondary);
  }

  .social-links .external:hover {
    color: var(--accent-secondary);
  }

  .social-links .primary {
    color: var(--accent);
  }

  .social-links svg {
    width: 16px;
    height: 16px;
  }
</style>
