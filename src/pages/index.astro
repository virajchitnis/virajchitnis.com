---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import SelectedWork from '../components/SelectedWork.astro';
import SocialLinks from '../components/SocialLinks.astro';
import ContactForm from '../components/ContactForm.astro';
import { getCollection, getEntry, render } from 'astro:content';

const profileEntry = await getEntry('profile', 'profile');
if (!profileEntry) throw new Error('Missing src/content/profile.md entry');
const { Content } = await render(profileEntry);
const workEntries = (await getCollection('work')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={profileEntry.data.name} description={profileEntry.data.tagline}>
  <div class="page">
    <Hero name={profileEntry.data.name} tagline={profileEntry.data.tagline} />
    <About>
      <Content />
    </About>
    <SelectedWork items={workEntries.map((entry) => entry.data)} />
    <SocialLinks links={profileEntry.data.links} />
    <ContactForm />
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }
</style>
